.DS_Store

# --- Python / venv / caches ---
.venv/
venv/
__pycache__/
*.py[cod]

# --- Logs / backups / residuos ---
*.log
*.bak
*.bad

# --- SQLite local (NO versionar) ---
invoicing.db
invoicing.db-*
invoicing.db.*
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
sqlite_aux_backup/

# Old DB recovery artifacts — do not commit
dump_recover.sql
fixed.db

# --- Storage local (NO versionar) ---
storage/**
!storage/
!storage/.gitkeep
!storage/README.md

# --- Keys/certs (NUNCA versionar) ---
keys/**
!keys/
!keys/README.md

# --- Backups locales (NO versionar) ---
backup/
backups/

# --- Secrets ---
.env

# Snapshot de respaldo: no editar ni commitear (ver docs/GUARDRAILS.md)
_snapshot_before_mindtrip/
