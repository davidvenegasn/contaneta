# ContaNeta — Production Environment Variables
# Copy to /var/lib/contaneta/.env and fill with real values.
# chmod 600 /var/lib/contaneta/.env

# ── Core (REQUIRED) ──────────────────────────────────────────
ENV=prod
DEV_MODE=0
ALLOW_DEMO_PORTAL=0

# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=CHANGE_ME_REQUIRED
AT_REST_MASTER_KEY=CHANGE_ME_RECOMMENDED

# ── Paths ─────────────────────────────────────────────────────
APP_DB_PATH=/var/lib/contaneta/invoicing.db
APP_STORAGE_PATH=/var/lib/contaneta/storage
BACKUP_DIR=/var/backups/contaneta
LOG_FILE=/var/log/contaneta/app.log

# ── Site ──────────────────────────────────────────────────────
SITE_URL=https://YOUR_DOMAIN.com
COOKIE_SECURE=1

# ── Stripe (optional — only if billing enabled) ──────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...

# ── Facturapi (optional — only if CFDI stamping enabled) ─────
# FACTURAPI_API_KEY=...

# ── SAT Sync ─────────────────────────────────────────────────
PHP_BIN=php
SAT_SYNC_BACKFILL_DAYS=7
SAT_SYNC_WINDOW_HOURS=6

# ── Admin Access ──────────────────────────────────────────────
# ADMIN_PASSWORD=CHANGE_ME

# ── Logging ───────────────────────────────────────────────────
LOG_REQUEST_ID=1
LOG_REQUESTS=1

# ── Sentry (optional) ────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_TRACES_RATE=0.1
