# Logrotate config for ContaNeta application logs.
# Copy to /etc/logrotate.d/contaneta and adjust paths if needed.
# If only using journald (systemd), this file is optional.

/var/log/contaneta/*.log {
    daily
    rotate 14
    compress
    delaycompress
    missingok
    notifempty
    copytruncate
    su contaneta contaneta
}
