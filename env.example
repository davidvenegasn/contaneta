# Copiar a .env y ajustar valores. En producción usar defaults seguros (DEV_MODE=0, COOKIE_SECURE=1).

# ---------- Entorno ----------
# En producción: 0 (obligatorio login). En desarrollo: 1 (permite acceso con DEV_TOKEN sin sesión).
DEV_MODE=0

# Token usado cuando DEV_MODE=1 para entrar al portal sin login. No usar en producción.
DEV_TOKEN=demo

# ---------- Base de datos ----------
# Ruta a invoicing.db. En producción usar ruta absoluta.
# APP_DB_PATH=/var/app/invoicing.db
APP_DB_PATH=

# ---------- Sesión y cookies ----------
# Secreto para firmar la cookie de sesión (32+ caracteres hex recomendado). Obligatorio en producción.
# python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Nombre de la cookie de sesión (default: portal_session).
# SESSION_COOKIE_NAME=portal_session

# Días de validez de la sesión (default: 7).
# SESSION_TTL_DAYS=7

# En producción con HTTPS: 1. Con 0 la cookie se envía por HTTP (solo desarrollo).
COOKIE_SECURE=0

# ---------- Facturación (Facturapi) ----------
# Clave secreta de Facturapi para timbrado. Necesaria para emitir facturas reales.
# FACTURAPI_SECRET_KEY=

# ---------- OAuth (opcional) ----------
# Para "Entrar con Google" / "Entrar con Facebook". Si no se definen, no se muestran botones.
# SITE_URL=https://tudominio.com
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=

# ---------- Otros ----------
# Email del usuario "despacho" para autorizar acceso como contador (opcional).
# FIRM_USER_EMAIL=

# ID del issuer usado como demo cuando DEV_MODE=1 y cookie portal_demo_view (opcional).
# DEMO_ISSUER_ID=
