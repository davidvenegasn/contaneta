# =============================================================================
# Conta Invoicing — Variables de entorno
# Copiar a .env y rellenar valores. NO subir .env al repositorio.
# =============================================================================

# ---------- AMBIENTE (DEV vs PROD) ----------
# DEV:   ENV=dev   (o no definir) → desarrollo; default DEV_MODE=1, COOKIE_SECURE=0
# PROD:  ENV=prod                 → producción; default DEV_MODE=0, COOKIE_SECURE=1
ENV=dev

# Modo desarrollo: 1 = permite lógica de desarrollo (ej. log de emails). Default según ENV.
DEV_MODE=1

# Si 1 y DEV_MODE=1: sin cookie válida las rutas HTML del portal pueden usar issuer demo (evita redirigir a /login).
# Si 0 (default): sin cookie siempre redirect /login (HTML) o 401 (API). Recomendado 0 para no "brincar" al demo.
ALLOW_DEMO_PORTAL=0

# Token de acceso rápido cuando ALLOW_DEMO_PORTAL=1. No usar en producción.
DEV_TOKEN=demo

# Si 1: GET /api/customers, /api/products, /api/invoices/issued, /api/invoices/received devuelven
# el JSON de tests/manual_fixtures/*.json en lugar de consultar la DB. Útil para desarrollar UI sin SAT/DB.
# DEV_FIXTURES=1

# ---------- PRODUCCIÓN (obligatorios al lanzar) ----------
# Ver SECURITY_MINIMUM.md para mínimos de seguridad (CSRF, headers, rate limit).
# En .env de producción:
#   ENV=prod
#   DEV_MODE=0
#   SESSION_SECRET=<OBLIGATORIO en prod; si falta, la app NO arranca (RuntimeError)>
#   COOKIE_SECURE=1   (si usas HTTPS)
#   APP_DB_PATH=/ruta/absoluta/invoicing.db
#   SITE_URL=https://tudominio.com  (para redirects de login, billing, OAuth)

# ---------- Base de datos ----------
# Ruta a invoicing.db. En producción usar ruta absoluta.
# APP_DB_PATH=/var/app/invoicing.db
APP_DB_PATH=

# ---------- Sesión y cookies ----------
# Secreto para firmar la cookie de sesión. En producción OBLIGATORIO: si ENV=prod y falta, la app NO arranca (RuntimeError).
# En dev, si falta se usa un valor aleatorio (solo válido para esa ejecución) y se emite un warning.
# Generar: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Cookie solo por HTTPS. Default: 0 en local (ENV=dev), 1 en prod. En local con HTTP usar 0.
COOKIE_SECURE=0

# SESSION_COOKIE_NAME=portal_session
# SESSION_TTL_DAYS=7

# ---------- Facturación (Facturapi) ----------
# Clave secreta para timbrado real. Necesaria para emitir facturas.
# FACTURAPI_SECRET_KEY=

# ---------- Email (SMTP) ----------
# Para verificación de correo y recuperación de contraseña. Sin configurar, en DEV los enlaces se muestran en consola.
# SMTP_HOST=smtp.ejemplo.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@tudominio.com

# ---------- URL del sitio y OAuth (opcional) ----------
# SITE_URL: URL base del sitio (ej. https://tudominio.com). Usado en redirects de login, billing (Stripe), OAuth.
# En producción con Stripe o OAuth debe coincidir con la URL real del sitio.
# En prod con Stripe activo, SITE_URL es recomendado (redirects de checkout).
# SITE_URL=https://tudominio.com
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=

# ---------- Stripe (suscripciones) ----------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID=

# ---------- Seguridad ----------
# En producción: ENV=prod, SESSION_SECRET obligatorio (la app no arranca sin él), COOKIE_SECURE=1 con HTTPS.
# No usar ALLOW_DEMO_PORTAL=1 ni DEV_MODE=1 en prod.

# Clave maestra para cifrado at-rest (FIEL/CSD). 32 bytes en hex o base64url.
# Si no se define, se deriva de SESSION_SECRET. Recomendado: clave independiente.
# Generar: python3 -c "import secrets; print(secrets.token_hex(32))"
# AT_REST_MASTER_KEY=

# Contraseña del panel admin (/admin/). Requerida si deseas acceder al admin.
# ADMIN_PASSWORD=

# ---------- UI Portal ----------
# Shell V2: rail delgado a la izquierda (solo iconos, tipo Mindtrip). En ENV=dev el default es 1; en prod 0.
# PORTAL_SHELL_V2=1

# ---------- Otros ----------
# FIRM_USER_EMAIL=   (usuario despacho/contador)
# DEMO_ISSUER_ID=    (issuer demo cuando DEV_MODE=1)
# LOG_FILE=          (ruta archivo de log)
# LOG_REQUEST_ID=0   (desactivar ID en logs)
